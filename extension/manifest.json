{
  "manifest_version": 3,
  "name": "Charles Autofill",
  "version": "1.0.0",
  "description": "Auto-fill job applications from your Charles resume profile",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "dist/background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Charles Autofill"
  }
}
